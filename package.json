{
  "name": "jupyter-browser-kernel",
  "displayName": "Jupyter Browser Kernel",
  "description": "Connect to a running Browser instance via CDP for variable watching, JS scratchpad execution, and log streaming.",
  "version": "0.0.1",
  "publisher": "sylvercode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Debuggers",
    "Notebooks",
    "Other"
  ],
  "main": "./dist/extension.js",
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterBrowserKernel.connect",
        "title": "Jupyter Browser Kernel: Connect via CDP"
      }
    ],
    "configuration": {
      "title": "Jupyter Browser Kernel",
      "properties": {
        "jupyterBrowserKernel.cdpHost": {
          "type": "string",
          "default": "localhost",
          "description": "Hostname or IP of the CDP endpoint."
        },
        "jupyterBrowserKernel.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "CDP remote debugging port."
        },
        "jupyterBrowserKernel.watchAutoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "Auto-refresh interval in ms for the variable watcher. 0 = disabled."
        }
      }
    }
  },
  "scripts": {
    "bmad:sync:build": "mkdir -p .tmp && esbuild scripts/bmad-github-sync.ts --bundle --platform=node --format=cjs --outfile=.tmp/bmad-github-sync.cjs",
    "bmad:sync": "npm run bmad:sync:build && node .tmp/bmad-github-sync.cjs",
    "bmad:sync:dry": "BMAD_SYNC_DRY_RUN=true npm run bmad:sync",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "npm run compile -- --watch",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}

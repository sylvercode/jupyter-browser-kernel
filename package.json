{
  "name": "jupyter-browser-kernel",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.1",
  "publisher": "sylvercode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.92.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Debuggers",
    "Notebooks",
    "Other"
  ],
  "main": "./dist/extension.mjs",
  "l10n": "./l10n",
  "extensionDependencies": [],
  "contributes": {
    "commands": [
      {
        "command": "jupyterBrowserKernel.connect",
        "title": "%command.connect.title%"
      },
      {
        "command": "jupyterBrowserKernel.disconnect",
        "title": "%command.disconnect.title%"
      },
      {
        "command": "jupyterBrowserKernel.reconnect",
        "title": "%command.reconnect.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "jupyterBrowserKernel.cdpHost": {
          "type": "string",
          "default": "localhost",
          "description": "%configuration.cdpHost.description%",
          "markdownDescription": "%configuration.cdpHost.markdownDescription%"
        },
        "jupyterBrowserKernel.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "%configuration.cdpPort.description%",
          "minimum": 1,
          "maximum": 65535,
          "multipleOf": 1,
          "markdownDescription": "%configuration.cdpPort.markdownDescription%"
        },
        "jupyterBrowserKernel.watchAutoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "%configuration.watchAutoRefreshInterval.description%"
        }
      }
    }
  },
  "scripts": {
    "bmad:sync:build": "mkdir -p .tmp && esbuild scripts/bmad-github-sync.ts --bundle --platform=node --format=cjs --outfile=.tmp/bmad-github-sync.cjs",
    "bmad:sync": "npm run bmad:sync:build && node .tmp/bmad-github-sync.cjs",
    "bmad:sync:dry": "BMAD_SYNC_DRY_RUN=true npm run bmad:sync",
    "clean": "node -e \"const fs=require('fs'); for (const d of ['dist','out']) fs.rmSync(d,{ recursive: true, force: true });\"",
    "compile": "npm run clean && node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "package:vsix": "npm run compile && vsce package --allow-missing-repository --skip-license",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "npm run test:unit",
    "test:compile": "tsc -p tsconfig.test.json",
    "test:unit": "npm run test:compile && node scripts/run-node-tests.mjs out/tests/unit",
    "test:integration": "npm run test:compile && node scripts/run-node-tests.mjs out/tests/integration",
    "test:integration:cdp": "npm run test:compile && RUN_CDP_INTEGRATION=1 node scripts/run-node-tests.mjs out/tests/integration"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.34.0",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/chrome-remote-interface": "^0.33.0",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.92.0",
    "@types/ws": "^8.5.13",
    "@vscode/l10n": "^0.0.18",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  }
}

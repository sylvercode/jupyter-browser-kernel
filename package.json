{
  "name": "jupyter-browser-kernel",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.1",
  "publisher": "sylvercode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.92.0"
  },
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "categories": [
    "Debuggers",
    "Notebooks",
    "Other"
  ],
  "main": "./dist/extension.mjs",
  "l10n": "./l10n",
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "contributes": {
    "commands": [
      {
        "command": "jupyterBrowserKernel.connect",
        "title": "%command.connect.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "jupyterBrowserKernel.cdpHost": {
          "type": "string",
          "default": "localhost",
          "description": "%configuration.cdpHost.description%",
          "markdownDescription": "%configuration.cdpHost.markdownDescription%"
        },
        "jupyterBrowserKernel.cdpPort": {
          "type": "number",
          "default": 9222,
          "description": "%configuration.cdpPort.description%",
          "minimum": 1,
          "maximum": 65535,
          "multipleOf": 1,
          "markdownDescription": "%configuration.cdpPort.markdownDescription%"
        },
        "jupyterBrowserKernel.watchAutoRefreshInterval": {
          "type": "number",
          "default": 0,
          "description": "%configuration.watchAutoRefreshInterval.description%"
        }
      }
    }
  },
  "scripts": {
    "bmad:sync:build": "mkdir -p .tmp && esbuild scripts/bmad-github-sync.ts --bundle --platform=node --format=cjs --outfile=.tmp/bmad-github-sync.cjs",
    "bmad:sync": "npm run bmad:sync:build && node .tmp/bmad-github-sync.cjs",
    "bmad:sync:dry": "BMAD_SYNC_DRY_RUN=true npm run bmad:sync",
    "compile": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "chrome-remote-interface": "^0.33.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.92.0",
    "@vscode/l10n": "^0.0.18",
    "@vscode/test-electron": "^2.3.8",
    "esbuild": "^0.20.0",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0"
  }
}
